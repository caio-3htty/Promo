{
  "name": "prumo-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@10",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "web:dev": "npm --prefix promo_APP_Web run dev",
    "web:lint": "npm --prefix promo_APP_Web run lint",
    "web:test": "npm --prefix promo_APP_Web run test",
    "web:build": "npm --prefix promo_APP_Web run build",
    "env:doctor": "node scripts/env-doctor.mjs",
    "clean": "node scripts/clean-root.mjs",
    "clean:all": "npm run clean && npm --prefix promo_APP_Web run clean --if-present && npm --prefix promo_APP_OwnerWindows run clean --if-present && npm --prefix promo_APP_Windows run clean --if-present && node scripts/clean-android-native.mjs",
    "owner:build": "npm --prefix promo_APP_OwnerWindows run build",
    "windows:build": "npm --prefix promo_APP_Windows run desktop:build:win",
    "linux:build": "node scripts/linux-build.mjs",
    "android:doctor": "node scripts/env-doctor.mjs --android",
    "android:lint": "node scripts/android-gradle.mjs lintDebug",
    "android:test": "node scripts/android-gradle.mjs testDebugUnitTest",
    "android:build": "npm run android:doctor && node scripts/android-gradle.mjs lintDebug testDebugUnitTest assembleDebug",
    "supabase:test": "node scripts/test-supabase.mjs",
    "supabase:validate:access": "node scripts/validate-access-login.mjs",
    "smoke:rbac": "node scripts/smoke-rbac-provision.mjs",
    "alerts:dispatch": "node scripts/process-critical-alerts.mjs",
    "alerts:dispatch:dry": "node scripts/process-critical-alerts.mjs --dry-run"
  }
}
