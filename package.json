{
  "name": "prumo-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@10",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "web:dev": "npm --prefix promo_APP_Web run dev",
    "web:lint": "npm --prefix promo_APP_Web run lint",
    "web:test": "npm --prefix promo_APP_Web run test",
    "web:build": "npm --prefix promo_APP_Web run build",
    "env:doctor": "node scripts/env-doctor.mjs",
    "clean": "node scripts/clean-root.mjs",
    "clean:all": "node scripts/clean-all.mjs",
    "owner:build": "npm --prefix promo_APP_OwnerWindows run build",
    "windows:build": "npm --prefix promo_APP_Windows run desktop:build:win",
    "linux:build": "node scripts/linux-build.mjs",
    "android:doctor": "node scripts/env-doctor.mjs --android",
    "android:lint": "node scripts/android-gradle.mjs lintDebug",
    "android:test": "node scripts/android-gradle.mjs testDebugUnitTest",
    "android:build": "npm run android:doctor && node scripts/android-gradle.mjs lintDebug testDebugUnitTest assembleDebug",
    "supabase:test": "node scripts/test-supabase.mjs",
    "supabase:validate:access": "node scripts/validate-access-login.mjs",
    "smoke:rbac": "node scripts/smoke-rbac-provision.mjs",
    "alerts:dispatch": "node scripts/process-critical-alerts.mjs",
    "alerts:dispatch:dry": "node scripts/process-critical-alerts.mjs --dry-run",
    "cleanup:web": "npm --prefix promo_APP_Web run cleanup:verify",
    "cleanup:android": "npm run android:doctor && node scripts/android-gradle.mjs lintDebug testDebugUnitTest assembleDebug assembleRelease",
    "cleanup:windows": "npm --prefix promo_APP_Windows run cleanup:verify",
    "cleanup:owner": "npm --prefix promo_APP_OwnerWindows run cleanup:verify",
    "cleanup:linux": "npm --prefix promo_APP_Linux run cleanup:verify",
    "cleanup:full-pass": "npm run cleanup:web && npm run cleanup:android && npm run cleanup:windows && npm run cleanup:owner && npm run cleanup:linux",
    "wave3:web:persona": "node scripts/wave3-web-persona.mjs",
    "wave3:desktop:smoke": "node scripts/wave3-desktop-shell-smoke.mjs",
    "wave3:android:functional": "node scripts/wave3-android-functional.mjs",
    "test:waves:auto": "node scripts/master-test-run.mjs --waves=wave1,wave2,wave4",
    "test:waves:full": "node scripts/master-test-run.mjs --waves=wave1,wave2,wave3,wave4",
    "test:waves:wave1": "node scripts/master-test-run.mjs --waves=wave1",
    "test:waves:wave2": "node scripts/master-test-run.mjs --waves=wave2",
    "test:waves:wave3": "node scripts/master-test-run.mjs --waves=wave3",
    "test:waves:wave4": "node scripts/master-test-run.mjs --waves=wave4"
  }
}
