{
  "name": "prumo-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@10",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "web:dev": "npm --prefix prumo-web-client run dev",
    "web:lint": "npm --prefix prumo-web-client run lint",
    "web:test": "npm --prefix prumo-web-client run test",
    "web:build": "npm --prefix prumo-web-client run build",
    "clean": "node scripts/clean-root.mjs",
    "clean:all": "npm run clean && npm --prefix prumo-web-client run clean && npm --prefix prumo-owner-windows run clean && npm --prefix prumo-windows-client run clean && npm --prefix prumo-android-client run clean",
    "owner:build": "npm --prefix prumo-owner-windows run build",
    "windows:build": "npm --prefix prumo-windows-client run build",
    "android:typecheck": "npm --prefix prumo-android-client run typecheck --if-present",
    "android:doctor": "npm --prefix prumo-android-client run doctor --if-present",
    "supabase:test": "node scripts/test-supabase.mjs",
    "smoke:rbac": "node scripts/smoke-rbac-provision.mjs"
  }
}
