# Workspace scripts (.env for local execution)
# Supabase API connectivity
SUPABASE_PROJECT_REF="your-project-ref"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Optional aliases accepted by scripts/env resolver
SUPABASE_SECRET_KEY="your-service-role-key"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
# Optional: if omitted, smoke script will auto-discover first tenant
SUPABASE_TENANT_ID="00000000-0000-0000-0000-000000000000"
VALIDATION_LOGIN_EMAIL="validacao-login@empresa.com"
VALIDATION_LOGIN_PASSWORD="senha-forte-validacao"

# Edge functions (Resend)
RESEND_API_KEY="re_xxxxxxxxx"
RESEND_FROM_EMAIL="Prumo <noreply@prumo.app>"
CRITICAL_ALERT_FALLBACK_EMAIL="engenheiro@example.com"

# Smoke test users (required by scripts/smoke-rbac-provision.mjs)
# Optional defaults (when specific role credentials are omitted)
SMOKE_DEFAULT_PASSWORD="Smoke1050!"
SMOKE_EMAIL_PREFIX="smoke.prumo"

# Role-specific overrides (optional)
SMOKE_GESTOR_EMAIL="gestor@example.com"
SMOKE_GESTOR_PASSWORD="change-me"
SMOKE_GESTOR_FULL_NAME="Gestor Smoke"
SMOKE_GESTOR_SCOPE="AB"

SMOKE_OPERACIONAL_EMAIL="operacional@example.com"
SMOKE_OPERACIONAL_PASSWORD="change-me"
SMOKE_OPERACIONAL_FULL_NAME="Operacional Smoke"
SMOKE_OPERACIONAL_SCOPE="A"

SMOKE_ENGENHEIRO_EMAIL="engenheiro@example.com"
SMOKE_ENGENHEIRO_PASSWORD="change-me"
SMOKE_ENGENHEIRO_FULL_NAME="Engenheiro Smoke"
SMOKE_ENGENHEIRO_SCOPE="A"

SMOKE_ALMOXARIFE_EMAIL="almoxarife@example.com"
SMOKE_ALMOXARIFE_PASSWORD="change-me"
SMOKE_ALMOXARIFE_FULL_NAME="Almoxarife Smoke"
SMOKE_ALMOXARIFE_SCOPE="B"

